# Copy this file to .env and fill in real values before running any Fabric/Azure tooling.
# See docs/fabric-setup.md for what each value is and how to obtain it.
#
# The core CLI (generate, validate, transform) does not read this file and has
# no cloud dependency — it only matters once you load Gold output into Fabric.

# Azure AD app registration used to authenticate against Fabric/Azure APIs.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Target Fabric workspace and lakehouse.
FABRIC_WORKSPACE_ID=
FABRIC_LAKEHOUSE_ID=

# Optional: only needed if staging Gold output through Azure Blob Storage / OneLake
# shortcuts before loading into the Fabric Lakehouse.
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_CONNECTION_STRING=
